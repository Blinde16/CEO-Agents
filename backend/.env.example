# OpenAI API
OPENAI_API_KEY=sk-...

# Model overrides (optional — defaults shown)
OPENAI_MODEL=gpt-4.1-mini   # fast/cheap: triage, conversational turns
OPENAI_MODEL_HEAVY=gpt-4.1  # quality: email drafts, meeting briefings

# Google OAuth (for Gmail + Calendar integration)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# App base URL (used for OAuth callback redirects)
APP_BASE_URL=http://localhost:3000
