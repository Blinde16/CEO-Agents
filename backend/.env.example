# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model overrides (optional — defaults shown)
OPENAI_MODEL=gpt-4.1-mini        # fast/cheap: triage, conversational turns
OPENAI_MODEL_HEAVY=gpt-4.1       # quality: email drafts, meeting briefings

# ── Google OAuth (Gmail + Calendar) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (zero-config local dev — default when DATABASE_URL is not set):
#   Leave DATABASE_URL unset or use:
#   DATABASE_URL=sqlite:///./ceo_agents.db
#
# Postgres (docker-compose or managed cloud DB):
DATABASE_URL=postgresql://ceo:ceopassword@localhost:5432/ceo_agents

# ── n8n Integration ───────────────────────────────────────────────────────────
# Shared secret sent in X-N8N-Secret header by n8n HTTP Request nodes.
# Set the same value in n8n as an environment variable (N8N_WEBHOOK_SECRET).
# Leave empty to disable webhook authentication (not recommended in production).
N8N_WEBHOOK_SECRET=change-me-to-a-random-secret

# ── Docker Compose extras ─────────────────────────────────────────────────────
POSTGRES_PASSWORD=ceopassword
N8N_ENCRYPTION_KEY=change-me-in-production
