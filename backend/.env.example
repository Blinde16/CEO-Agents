# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (optional — defaults shown)
CLAUDE_MODEL=claude-haiku-4-5-20251001        # fast/cheap: triage, conversational turns
CLAUDE_MODEL_HEAVY=claude-sonnet-4-6          # quality: email drafts, meeting briefings

# Google OAuth (for Gmail + Calendar integration)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google/callback

# App base URL (used for OAuth callback redirects)
APP_BASE_URL=http://localhost:3000
